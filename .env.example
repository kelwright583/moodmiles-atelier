# Supabase (required for the app to run)
# Get these from: Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key
VITE_SUPABASE_PROJECT_ID=YOUR_PROJECT_REF

# Supabase Edge Functions (set in Supabase Dashboard > Project Settings > Edge Functions > Secrets)
# OPENAI_API_KEY=sk-...       # Required - from platform.openai.com - powers outfits, packing, activities, trends
# GOOGLE_MAPS_API_KEY=        # Required - from console.cloud.google.com - Places autocomplete, destination & activity images
# FIRECRAWL_API_KEY=          # Required for search-fashion, optional for activities & trends - from firecrawl.dev
# UNSPLASH_ACCESS_KEY=        # Optional fallback for images - free at unsplash.com/developers
